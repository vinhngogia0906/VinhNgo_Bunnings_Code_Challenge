FROM node:24-alpine AS build
WORKDIR /src
# Lock file generated by npm 11.x — bump the container's bundled npm 10.x so
# `npm ci` understands the platform-specific peer dependency entries.
RUN npm install -g npm@11
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build


FROM nginx:1.27-alpine AS final
COPY --from=build /src/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80